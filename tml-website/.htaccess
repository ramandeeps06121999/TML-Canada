Options -Indexes
DirectoryIndex index.php

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Serve existing files directly; directories are handled by index.php
  RewriteCond %{REQUEST_FILENAME} -f
  RewriteRule ^ - [L]

  # Route everything else through index.php
  RewriteRule ^ index.php [L]
</IfModule>

# Block direct access to data/config files
<FilesMatch "\.(json|md)$">
  <IfModule mod_authz_core.c>
    Require all denied
  </IfModule>
  <IfModule !mod_authz_core.c>
    Order allow,deny
    Deny from all
  </IfModule>
</FilesMatch>
